{
  "name": "Grok Be Gone!",
  "version": "1.3",
  "manifest_version": 3,
  "description": "Remove GROK from your life!",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["https://x.com/*"],
  "action": {
    "default_popup": "grok-be-gone-popup.html",
    "default_icon": "grok-be-gone.png"
  },
  "content_scripts": [
    {
      "js": ["scripts/content.js"],
      "matches": ["https://x.com/*"],
      "type": "module"
    }
  ]
}
